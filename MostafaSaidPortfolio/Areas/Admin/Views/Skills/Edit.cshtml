@model MostafaSaidPortfolio.Domain.Entities.Skill
@{
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Edit Skill";
    var categories = MostafaSaidPortfolio.Domain.Entities.Skill.ValidCategories;
}

<div class="max-w-xl">
    <div class="stat-card">
        <h2 class="text-lg font-semibold text-white mb-6">Edit Skill — <span class="text-indigo-400">@Model.Name</span></h2>

        <form asp-area="Admin" asp-controller="Skills" asp-action="Edit" asp-route-id="@Model.Id" method="post" novalidate>
            @Html.AntiForgeryToken()
            <input asp-for="Id" type="hidden" />
            <div class="space-y-5">

                <div>
                    <label asp-for="Name" class="form-label">Skill Name <span class="text-red-400">*</span></label>
                    <input asp-for="Name" class="form-input" required maxlength="100" />
                    <span asp-validation-for="Name" class="text-red-400 text-xs mt-1 block"></span>
                </div>

                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <label asp-for="Category" class="form-label">Category</label>
                        <select asp-for="Category" class="form-input">
                            @foreach (var cat in categories)
                            {
                                <option value="@cat" selected="@(Model.Category == cat)">@cat</option>
                            }
                        </select>
                    </div>
                    <div>
                        <label asp-for="Proficiency" class="form-label">Proficiency (0–100)</label>
                        <input asp-for="Proficiency" type="number" min="0" max="100" class="form-input" />
                    </div>
                </div>

                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <label asp-for="IconName" class="form-label">Icon / Emoji</label>
                        <input asp-for="IconName" class="form-input" maxlength="100" />
                    </div>
                    <div>
                        <label asp-for="DisplayOrder" class="form-label">Display Order</label>
                        <input asp-for="DisplayOrder" type="number" class="form-input" />
                    </div>
                </div>

                <div>
                    <label asp-for="Description" class="form-label">Description</label>
                    <textarea asp-for="Description" rows="3" class="form-input"></textarea>
                </div>

                <div class="flex items-center gap-3">
                    <input asp-for="IsActive" type="checkbox" id="IsActive"
                           class="w-4 h-4 rounded border-slate-600 bg-slate-800 text-indigo-600" />
                    <label for="IsActive" class="text-sm text-slate-300">Active (visible on portfolio)</label>
                </div>

                <div class="text-xs text-slate-500 pt-2 border-t border-slate-700">
                    Created: @Model.CreatedAt.ToString("MMM d, yyyy HH:mm") UTC ·
                    Last updated: @Model.UpdatedAt.ToString("MMM d, yyyy HH:mm") UTC
                </div>

                <div class="flex items-center gap-3">
                    <button type="submit" class="btn-primary">Save Changes</button>
                    <a href="/Admin/Skills" class="btn-ghost">Cancel</a>
                </div>
            </div>
        </form>
    </div>
</div>
