@using MostafaSaidPortfolio.ViewModels
@model ContactViewModel
@{ ViewData["Title"] = L["Contact_Title"].ToString(); }

<!-- Page Header -->
<section class="page-header">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <p class="text-indigo-400 font-semibold text-xs uppercase tracking-widest mb-3">@L["Contact_Label"]</p>
        <h1 class="font-heading text-4xl sm:text-5xl font-bold text-white mb-4">@L["Contact_Title"]</h1>
        <p class="text-slate-400 text-lg max-w-xl">@L["Contact_Description"]</p>
    </div>
</section>

<section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-20">
    <div class="grid lg:grid-cols-5 gap-12">

        <!-- Contact Info -->
        <div class="lg:col-span-2 observe-fade">
            <h2 class="font-heading font-bold text-2xl mb-6" style="color:var(--text-primary)">@L["Contact_WorkTogether"]</h2>
            <p class="leading-relaxed mb-8 text-sm" style="color:var(--text-secondary)">@L["Contact_BodyText"]</p>

            <ul class="space-y-5">
                <li class="flex items-start gap-4">
                    <div class="w-10 h-10 rounded-xl flex items-center justify-center shrink-0" style="background:var(--accent-bg);border:1px solid var(--accent-border)">
                        <svg class="w-5 h-5" style="color:var(--accent)" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                        </svg>
                    </div>
                    <div>
                        <div class="font-semibold text-sm" style="color:var(--text-primary)">@L["Contact_EmailLabel"]</div>
                        <a href="mailto:mostafa@example.com" class="text-sm" style="color:var(--accent)">mostafa@example.com</a>
                    </div>
                </li>
                <li class="flex items-start gap-4">
                    <div class="w-10 h-10 rounded-xl flex items-center justify-center shrink-0" style="background:var(--accent-bg);border:1px solid var(--accent-border)">
                        <svg class="w-5 h-5" style="color:var(--accent)" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                        </svg>
                    </div>
                    <div>
                        <div class="font-semibold text-sm" style="color:var(--text-primary)">@L["Contact_LocationLabel"]</div>
                        <div class="text-sm" style="color:var(--text-secondary)">Cairo, Egypt</div>
                    </div>
                </li>
                <li class="flex items-start gap-4">
                    <div class="w-10 h-10 rounded-xl flex items-center justify-center shrink-0" style="background:#d1fae5;border:1px solid #a7f3d0">
                        <span class="w-2.5 h-2.5 bg-emerald-500 rounded-full animate-pulse"></span>
                    </div>
                    <div>
                        <div class="font-semibold text-sm" style="color:var(--text-primary)">@L["Contact_AvailLabel"]</div>
                        <div class="text-sm font-medium text-emerald-600">@L["Contact_AvailValue"]</div>
                    </div>
                </li>
            </ul>

            <div class="flex gap-3 mt-8">
                <a href="https://github.com/mostafasaid" target="_blank" rel="noopener"
                   class="w-10 h-10 rounded-xl flex items-center justify-center transition-all"
                   style="background:var(--bg-subtle);color:var(--text-secondary);border:1px solid var(--border)">
                    <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/></svg>
                </a>
                <a href="https://linkedin.com/in/mostafasaid" target="_blank" rel="noopener"
                   class="w-10 h-10 rounded-xl flex items-center justify-center transition-all"
                   style="background:var(--bg-subtle);color:var(--text-secondary);border:1px solid var(--border)">
                    <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
                </a>
            </div>
        </div>

        <!-- Contact Form -->
        <div class="lg:col-span-3 observe-fade delay-200">
            <div class="form-card">
                <h3 class="font-heading font-bold text-xl mb-6" style="color:var(--text-primary)">@L["Contact_FormTitle"]</h3>

                @if (!ViewData.ModelState.IsValid && ViewData.ModelState.ErrorCount > 0)
                {
                    <div class="mb-6 p-4 bg-red-50 border border-red-200 rounded-xl text-red-700 text-sm dark:bg-red-950/40 dark:border-red-800 dark:text-red-400">
                        @L["Contact_Error"]
                    </div>
                }

                <form asp-action="Submit" method="post" class="space-y-5">
                    @Html.AntiForgeryToken()

                    <div class="grid sm:grid-cols-2 gap-5">
                        <div>
                            <label asp-for="Name" class="form-label block mb-1.5">@FL["Auth_Username"]</label>
                            <input asp-for="Name" class="form-input" placeholder="John Doe"/>
                            <span asp-validation-for="Name" class="text-red-500 text-xs mt-1 block"></span>
                        </div>
                        <div>
                            <label asp-for="Email" class="form-label block mb-1.5">@FL["Auth_Email"]</label>
                            <input asp-for="Email" class="form-input" placeholder="john@example.com"/>
                            <span asp-validation-for="Email" class="text-red-500 text-xs mt-1 block"></span>
                        </div>
                    </div>

                    <div>
                        <label asp-for="Subject" class="form-label block mb-1.5">
                            @L["Contact_Subject"] <span class="font-normal" style="color:var(--text-muted)">(@L["Contact_SubjectOptional"])</span>
                        </label>
                        <input asp-for="Subject" class="form-input" placeholder="Project inquiry, freelance work…"/>
                    </div>

                    <div>
                        <label asp-for="Message" class="form-label block mb-1.5">@L["Contact_Message"]</label>
                        <textarea asp-for="Message" class="form-input resize-none" rows="6"
                                  placeholder="Tell me about your project, timeline, and budget…"></textarea>
                        <span asp-validation-for="Message" class="text-red-500 text-xs mt-1 block"></span>
                    </div>

                    <button type="submit"
                            class="w-full py-3.5 bg-indigo-600 hover:bg-indigo-500 text-white font-bold rounded-xl transition-all duration-200 hover:-translate-y-0.5 shadow-lg shadow-indigo-500/30 hover:shadow-indigo-500/50">
                        @L["Contact_Send"] →
                    </button>
                </form>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial"/>
}
