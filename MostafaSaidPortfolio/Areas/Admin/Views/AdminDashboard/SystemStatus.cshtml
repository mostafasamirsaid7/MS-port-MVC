@{
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "System Status";
    var dbBlog    = (int)(ViewData["DbBlogCount"] ?? 0);
    var dbProject = (int)(ViewData["DbProjectCount"] ?? 0);
    var dbSkill   = (int)(ViewData["DbSkillCount"] ?? 0);
}

<div class="max-w-2xl space-y-5">

    <div class="stat-card">
        <h2 class="font-semibold text-white mb-4">Service Health</h2>
        <div class="space-y-3">
            @{
                var services = new[]
                {
                    new { Name="ASP.NET Core 9.0",  Status="Operational",  Ok=true  },
                    new { Name="PostgreSQL Database", Status="Operational", Ok=true  },
                    new { Name="Dapper ORM",          Status="Operational", Ok=true  },
                    new { Name="Identity / Auth",     Status="Operational", Ok=true  },
                    new { Name="Localization (EN/AR)",Status="Operational", Ok=true  },
                    new { Name="Rate Limiter",        Status="Operational", Ok=true  },
                };
            }
            @foreach (var svc in services)
            {
                <div class="flex items-center justify-between py-2 border-b border-slate-700/50 last:border-0">
                    <span class="text-sm text-slate-300">@svc.Name</span>
                    <span class="badge @(svc.Ok ? "badge-green" : "badge-red")">@svc.Status</span>
                </div>
            }
        </div>
    </div>

    <div class="stat-card">
        <h2 class="font-semibold text-white mb-4">Database Row Counts</h2>
        <div class="space-y-3">
            <div class="flex justify-between text-sm py-2 border-b border-slate-700/50">
                <span class="text-slate-400">Blog Posts (total)</span>
                <span class="font-medium text-white">@dbBlog</span>
            </div>
            <div class="flex justify-between text-sm py-2 border-b border-slate-700/50">
                <span class="text-slate-400">Projects (total)</span>
                <span class="font-medium text-white">@dbProject</span>
            </div>
            <div class="flex justify-between text-sm py-2">
                <span class="text-slate-400">Skills (total)</span>
                <span class="font-medium text-white">@dbSkill</span>
            </div>
        </div>
    </div>

    <div class="stat-card">
        <h2 class="font-semibold text-white mb-4">Runtime Info</h2>
        <div class="space-y-2 text-sm">
            <div class="flex justify-between py-1.5 border-b border-slate-700/50">
                <span class="text-slate-400">Server Time (UTC)</span>
                <span class="text-white tabular-nums">@DateTime.UtcNow.ToString("yyyy-MM-dd HH:mm:ss")</span>
            </div>
            <div class="flex justify-between py-1.5 border-b border-slate-700/50">
                <span class="text-slate-400">Environment</span>
                <span class="badge badge-blue">@Environment.GetEnvironmentVariable("ASPNETCORE_ENVIRONMENT") ?? "Production"</span>
            </div>
            <div class="flex justify-between py-1.5">
                <span class="text-slate-400">.NET Version</span>
                <span class="text-white">@System.Runtime.InteropServices.RuntimeInformation.FrameworkDescription</span>
            </div>
        </div>
    </div>
</div>
