@model MostafaSaidPortfolio.Domain.Entities.Skill
@{
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Delete Skill";
}

<div class="max-w-md">
    <div class="stat-card border border-red-900/40">
        <div class="flex items-center gap-3 mb-5">
            <div class="w-10 h-10 rounded-xl bg-red-900/50 flex items-center justify-center">
                <svg class="w-5 h-5 text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/>
                </svg>
            </div>
            <div>
                <h2 class="font-semibold text-white">Delete Skill</h2>
                <p class="text-sm text-slate-400">This action cannot be undone.</p>
            </div>
        </div>

        <div class="bg-slate-800/60 rounded-xl p-4 mb-5 space-y-2">
            <div class="flex justify-between text-sm">
                <span class="text-slate-400">Name</span>
                <span class="font-medium text-white">@Model.Name</span>
            </div>
            <div class="flex justify-between text-sm">
                <span class="text-slate-400">Category</span>
                <span class="text-slate-300">@Model.Category</span>
            </div>
            <div class="flex justify-between text-sm">
                <span class="text-slate-400">Proficiency</span>
                <span class="text-slate-300">@Model.Proficiency%</span>
            </div>
        </div>

        <form asp-area="Admin" asp-controller="Skills" asp-action="Delete" asp-route-id="@Model.Id" method="post">
            @Html.AntiForgeryToken()
            <div class="flex gap-3">
                <button type="submit" class="btn-danger">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
                    Yes, Delete
                </button>
                <a href="/Admin/Skills" class="btn-ghost">Cancel</a>
            </div>
        </form>
    </div>
</div>
