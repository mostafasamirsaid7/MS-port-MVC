modules = ["dotnet-7.0", "web", "nodejs-20", "dotnet-9.0"]
[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd MostafaSaidPortfolio && ASPNETCORE_URLS=http://0.0.0.0:5000 dotnet run --no-launch-profile"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[ports]]
localPort = 5000
externalPort = 80

[deployment]
deploymentTarget = "autoscale"
run = ["bash", "-c", "cd MostafaSaidPortfolio && ASPNETCORE_URLS=http://0.0.0.0:5000 dotnet run --no-launch-profile"]
