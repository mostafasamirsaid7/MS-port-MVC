@using MostafaSaidPortfolio.Models
@{
    ViewData["Title"] = "Home";
}

<!-- Hero Section -->
<section class="relative bg-indigo-600 text-white py-24">
    <div class="container mx-auto px-6 text-center">
        <h1 class="text-4xl md:text-6xl font-bold mb-6">Welcome to My Portfolio</h1>
        <p class="text-lg md:text-xl mb-8 max-w-2xl mx-auto">
            I'm Mostafa Said — a developer passionate about building projects, sharing knowledge, and crafting digital solutions.
        </p>
        <div class="space-x-4">
            <a asp-controller="Projects" asp-action="Index"
               class="px-6 py-3 bg-white text-indigo-600 font-semibold rounded-lg shadow hover:bg-gray-200">
                View Projects
            </a>
            <a asp-controller="Blog" asp-action="Index"
               class="px-6 py-3 border border-white font-semibold rounded-lg hover:bg-indigo-700">
                Read Blog
            </a>
        </div>
    </div>
</section>

<!-- Latest Projects -->
<section class="container mx-auto px-6 py-16">
    <h2 class="text-2xl md:text-3xl font-bold text-center mb-12">Latest Projects</h2>
    <div class="grid md:grid-cols-3 gap-8">
        @foreach (var project in ViewBag.Projects ?? new List<Project>())
        {
            <div class="bg-white rounded-lg shadow hover:shadow-lg transition p-6">
                <img src="@project.ImageUrl" alt="@project.Title" class="rounded mb-4" />
                <h3 class="text-xl font-semibold mb-2">@project.Title</h3>
                <p class="text-sm text-gray-600 mb-4">@project.Description</p>
                <a href="@project.LiveUrl" target="_blank"
                   class="inline-block text-indigo-600 font-semibold hover:underline">
                    Live Demo →
                </a>
            </div>
        }
    </div>
    <div class="text-center mt-10">
        <a asp-controller="Projects" asp-action="Index"
           class="px-6 py-3 bg-indigo-600 text-white rounded-lg hover:bg-indigo-700">
            View All Projects
        </a>
    </div>
</section>

<!-- Latest Blog Posts -->
<section class="bg-gray-50 py-16">
    <div class="container mx-auto px-6">
        <h2 class="text-2xl md:text-3xl font-bold text-center mb-12">Latest Blog Posts</h2>
        <div class="grid md:grid-cols-3 gap-8">
            @foreach (var post in ViewBag.Blogs ?? new List<BlogPost>())
            {
                <div class="bg-white rounded-lg shadow hover:shadow-lg transition p-6">
                    <h3 class="text-xl font-semibold mb-2">@post.Title</h3>
                    <p class="text-sm text-gray-600 mb-4">@post.Content.Substring(0, Math.Min(post.Content.Length, 100))...</p>
                    <a asp-controller="Blog" asp-action="Details" asp-route-id="@post.Id"
                       class="inline-block text-indigo-600 font-semibold hover:underline">
                        Read More →
                    </a>
                </div>
            }
        </div>
        <div class="text-center mt-10">
            <a asp-controller="Blog" asp-action="Index"
               class="px-6 py-3 bg-indigo-600 text-white rounded-lg hover:bg-indigo-700">
                View All Blog Posts
            </a>
        </div>
    </div>
</section>

<!-- Subscribe Section (partial) -->
<partial name="Partials/_SubscribePartial" />
