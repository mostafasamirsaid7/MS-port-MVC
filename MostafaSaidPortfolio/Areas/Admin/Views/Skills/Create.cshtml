@model MostafaSaidPortfolio.Domain.Entities.Skill
@{
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Add Skill";
    var categories = MostafaSaidPortfolio.Domain.Entities.Skill.ValidCategories;
}

<div class="max-w-xl">
    <div class="stat-card">
        <h2 class="text-lg font-semibold text-white mb-6">Add New Skill</h2>

        <form asp-area="Admin" asp-controller="Skills" asp-action="Create" method="post" novalidate>
            @Html.AntiForgeryToken()
            <div class="space-y-5">

                <div>
                    <label asp-for="Name" class="form-label">Skill Name <span class="text-red-400">*</span></label>
                    <input asp-for="Name" class="form-input" placeholder="e.g. ASP.NET Core" required maxlength="100" />
                    <span asp-validation-for="Name" class="text-red-400 text-xs mt-1 block"></span>
                </div>

                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <label asp-for="Category" class="form-label">Category <span class="text-red-400">*</span></label>
                        <select asp-for="Category" class="form-input">
                            @foreach (var cat in categories)
                            {
                                <option value="@cat">@cat</option>
                            }
                        </select>
                    </div>
                    <div>
                        <label asp-for="Proficiency" class="form-label">Proficiency (0–100) <span class="text-red-400">*</span></label>
                        <input asp-for="Proficiency" type="number" min="0" max="100" class="form-input" />
                        <span asp-validation-for="Proficiency" class="text-red-400 text-xs mt-1 block"></span>
                    </div>
                </div>

                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <label asp-for="IconName" class="form-label">Icon / Emoji</label>
                        <input asp-for="IconName" class="form-input" placeholder="e.g. ⚡ or fa-bolt" maxlength="100" />
                        <p class="text-xs text-slate-500 mt-1">Emoji character or icon identifier</p>
                    </div>
                    <div>
                        <label asp-for="DisplayOrder" class="form-label">Display Order</label>
                        <input asp-for="DisplayOrder" type="number" class="form-input" />
                    </div>
                </div>

                <div>
                    <label asp-for="Description" class="form-label">Description</label>
                    <textarea asp-for="Description" rows="3" class="form-input" placeholder="Short description of how you use this skill…"></textarea>
                </div>

                <div class="flex items-center gap-3">
                    <input asp-for="IsActive" type="checkbox" id="IsActive"
                           class="w-4 h-4 rounded border-slate-600 bg-slate-800 text-indigo-600" checked />
                    <label for="IsActive" class="text-sm text-slate-300">Active (visible on portfolio)</label>
                </div>

                <div class="flex items-center gap-3 pt-2 border-t border-slate-700">
                    <button type="submit" class="btn-primary">Save Skill</button>
                    <a href="/Admin/Skills" class="btn-ghost">Cancel</a>
                </div>
            </div>
        </form>
    </div>
</div>
